# ─────────────────────────────────────────────────────────────────────────────
# PRODUKČNÝ .env PRE SERVER (docker compose).
# Skopíruj do koreňa repozitára ako `.env` a vyplň hodnoty:
#     cp deploy/.env.server.example .env
# Tento súbor je len šablóna — NIKDY sem nepíš reálne heslá/kľúče.
# Reálny `.env` je v .gitignore a NEcommituje sa.
# ─────────────────────────────────────────────────────────────────────────────

# ── Doména a URL ────────────────────────────────────────────────────────────
APP_DOMAIN=dokladovka.site
APP_BASE_URL=https://dokladovka.site
# Doména, na ktorej firmy dostávajú e-mailové aliasy (catch-all). Rovnaká ako
# doména stránky je najjednoduchšia (aliasy typu xxx@dokladovka.site).
MAIL_RECEIVING_DOMAIN=dokladovka.site

# ── Tajomstvá — vygeneruj náhodné:  openssl rand -base64 24 ──────────────────
POSTGRES_PASSWORD=CHANGE_ME_generate_random
MINIO_ROOT_USER=dokladovka
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_random
INBOUND_WEBHOOK_SECRET=CHANGE_ME_generate_random

# ── HTTPS session cookie (Caddy terminuje TLS) ──────────────────────────────
SESSION_COOKIE_SECURE=true

# ── OpenAI (extrakcia dokladov) ─────────────────────────────────────────────
DOCUMENT_EXTRACTION_PROVIDER=openai
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-5-mini
# Silnejšie modely sú opt-in; nechaj zakomentované, kým účet nepotvrdí prístup.
# OPENAI_ACCOUNTING_FALLBACK_MODEL=gpt-5.6-terra
# OPENAI_RULE_ANALYSIS_MODEL=gpt-5.6-sol
OPENAI_TIMEOUT_MS=300000
OPENAI_MAX_RETRIES=5

# ── IMAP príjem pošty (Namecheap Private Email, catch-all schránka) ──────────
IMAP_HOST=mail.privateemail.com
IMAP_PORT=993
IMAP_USER=zber@dokladovka.site
IMAP_PASSWORD=CHANGE_ME_mailbox_password
IMAP_POLL_INTERVAL=30

# ── Prvý admin (použije sa iba pri jednorazovom seed príkaze) ────────────────
SEED_ADMIN_EMAIL=admin@dokladovka.site
SEED_ADMIN_PASSWORD=CHANGE_ME_admin_password

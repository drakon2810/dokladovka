# Verejná display konfigurácia mock frontendu. Nie je to secret.
VITE_PUBLIC_MAIL_RECEIVING_DOMAIN=doklady.dokladorpro.sk
# Verejný prepínač adaptéra, nikdy nie heslo/token. Produkcia musí používať BFF.
VITE_AUTH_MODE=bff
VITE_DATA_MODE=rest

# Server-side hodnoty. Nikdy ich nepoužívajte s prefixom VITE_.
# Nikdy ich nepoužívajte s prefixom VITE_ ani vo frontend bundle.
MAIL_RECEIVING_DOMAIN=doklady.dokladorpro.sk
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001
PORT=3001
DATABASE_URL=postgresql://dokladovka:dokladovka@localhost:5432/dokladovka
# Lokálny PostgreSQL-WASM fallback, ak DATABASE_URL nie je nastavené.
# Na Windows sa predvolene ukladá mimo OneDrive do %LOCALAPPDATA%\Dokladovka\pglite.
# PGLITE_DATA_DIR=C:\absolutna\cesta\k\pglite
EMAIL_PROVISIONING_MODE=catch_all
EMAIL_ALIAS_TOKEN_LENGTH=6
EMAIL_ALIAS_GRACE_DAYS=30
INBOUND_EMAIL_PROVIDER=mock
INBOUND_WEBHOOK_SECRET=change-me
DOCUMENT_EXTRACTION_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_STORE_RESPONSES=false
AUTO_APPROVAL_ENABLED=false

OBJECT_STORAGE_MODE=s3
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=eu-central-1
OBJECT_STORAGE_BUCKET=dokladovka-private
OBJECT_STORAGE_ACCESS_KEY=change-me
OBJECT_STORAGE_SECRET_KEY=change-me
OBJECT_STORAGE_FORCE_PATH_STYLE=true

SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=8
WORKER_POLL_INTERVAL_MS=1500
AGENT_INSTALLER_PUBLIC_BASE_URL=http://localhost:3001/downloads
AGENT_OFFLINE_ALERT_HOURS=2
EXPORT_FAILURE_ALERT_PERCENT=20
MONITOR_INTERVAL_MS=60000

# Voliteľný prvotný admin. Seed sa bez oboch hodnôt nevykoná.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

{
  "name": "dokladovka",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "dev:monitor": "tsx watch server/monitor.ts",
    "db:migrate": "tsx server/db/runMigrations.ts",
    "db:seed": "tsx server/db/seed.ts",
    "typecheck": "tsc -b --pretty false",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start:api": "node build/server/index.js",
    "start:worker": "node build/server/worker.js",
    "start:monitor": "node build/server/monitor.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:pdfs": "node scripts/gen-pdfs.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@fastify/cookie": "^11.1.1",
    "@fastify/rate-limit": "^11.1.0",
    "bysquare": "^4.0.0",
    "date-fns": "^3.6.0",
    "fastify": "^5.10.0",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^9.1.1",
    "react-router-dom": "^6.30.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.10.6",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "~5.6.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
